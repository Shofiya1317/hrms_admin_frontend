{
    "name": "valence_admin",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build:local": "cross-env ENV_FILE=.env next build",
        "build:dev": "cross-env ENV_FILE=.env.example_dev next build",
        "build:prod": "cross-env ENV_FILE=.env.example_prod next build",
        "start": "next start -p 3001",
        "deploy:prod": "bash ./deploy.sh prod",
        "deploy:dev": "bash ./deploy.sh dev",
        "prepare": "husky",
        "precommit": "./.husky/pre-commit",
        "prepush": "./.husky/pre-push",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\" && npm run lint && npm run lint:fix",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch",
        "sonar": "sonar-scanner"
    },
    "dependencies": {
        "@google-cloud/translate": "^9.3.0",
        "@google/generative-ai": "^0.24.1",
        "@hello-pangea/dnd": "^18.0.1",
        "@next/font": "^14.2.15",
        "apexcharts": "^4.7.0",
        "axios": "^1.7.7",
        "bootstrap": "^5.3.3",
        "formik": "^2.4.6",
        "lodash": "^4.17.21",
        "moment": "^2.30.1",
        "next": "14.2.15",
        "next-auth": "^5.0.0-beta.16",
        "rc-time-picker": "^3.7.3",
        "react": "^18.3.1",
        "react-apexcharts": "^1.7.0",
        "react-avatar": "^5.0.3",
        "react-bootstrap": "^2.10.5",
        "react-data-table-component": "^7.6.2",
        "react-device-detect": "^2.2.3",
        "react-dom": "^18.3.1",
        "react-hot-toast": "^2.4.1",
        "react-icons": "^5.3.0",
        "react-loading-skeleton": "^3.5.0",
        "react-multi-date-picker": "^4.5.2",
        "react-phone-number-input": "^3.4.8",
        "react-select": "^5.8.1",
        "recharts": "^3.1.2",
        "sharp": "^0.33.5",
        "yup": "^1.4.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.0.1",
        "@types/jest": "^29.5.14",
        "@types/lodash": "^4.17.13",
        "@types/node": "^20.17.6",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "autoprefixer": "^10.4.20",
        "cross-env": "^7.0.3",
        "eslint": "^8.57.1",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-airbnb-typescript": "^18.0.0",
        "eslint-config-next": "14.2.8",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.30.0",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.36.1",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-typescript": "^0.14.0",
        "husky": "^9.1.6",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.4.45",
        "prettier": "^3.6.2",
        "sonarqube-scanner": "^4.2.5",
        "ts-jest": "^29.2.5",
        "typescript": "^4.9.5"
    }
}